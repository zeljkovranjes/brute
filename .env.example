
##############
# brute-http #  (standalone server)
##############

# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:{password}@{host}/{database}

# Bearer token required for all API and export endpoints.
BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API token for IPinfo.io — used for IP geolocation.
# Get one free at https://ipinfo.io/signup
IPINFO_TOKEN=xxxxxxxxxxxxxx

# API key for AbuseIPDB (optional).
# When set, abuse confidence scores are collected and cached per IP.
# Get one free at https://www.abuseipdb.com/register
ABUSEIPDB_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Logging
RUST_LOG=trace
RUST_LOG_STYLE=always

# Listen addresses
LISTEN_ADDRESS=0.0.0.0:7000
LISTEN_ADDRESS_TLS=0.0.0.0:7443

# Set to true when running inside Docker (adjusts migration path).
RUNNING_IN_DOCKER=false

################
# brute-daemon #  (honeypot daemon)
################

# Full URL to the brute-http attack ingestion endpoint.
# Use port 7000 (HTTP) or 7443 (HTTPS).
ADD_ATTACK_ENDPOINT=http://localhost:7000/brute/attack/add

# Must match the BEARER_TOKEN set in brute-http.
BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the SSH honeypot port (default: 22).
# PORT=22

#################
# brute-worker  #  (Cloudflare Workers — set via wrangler secret / [vars])
#################
# These are configured in brute-worker/wrangler.toml or via:
#   wrangler secret put BEARER_TOKEN
#   wrangler secret put ABUSEIPDB_KEY
#
# BEARER_TOKEN   — required, same purpose as brute-http
# ABUSEIPDB_KEY  — optional, same purpose as brute-http
#
# No IPINFO_TOKEN needed — geo data comes from the Cloudflare cf
# request object at no cost.
