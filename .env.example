
##############
# brute-http #  (standalone server)
##############

# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:{password}@{host}/{database}

# Bearer token required for all API and export endpoints.
BEARER_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IP geolocation via IPinfo.io — set one of the two options below.
#
# Option A — self-hosted round-robin proxy (no token needed, proxy handles auth):
#   Set IPINFO_BASE_URL to your proxy root URL and leave IPINFO_TOKEN empty.
IPINFO_BASE_URL=
#
# Option B — real IPinfo.io endpoint:
#   Leave IPINFO_BASE_URL empty and set IPINFO_TOKEN to your API token.
#   Get one free at https://ipinfo.io/signup
IPINFO_TOKEN=

# API key for AbuseIPDB (optional).
# When set, abuse confidence scores are collected and cached per IP.
# Get one free at https://www.abuseipdb.com/register
ABUSEIPDB_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Logging
RUST_LOG=trace
RUST_LOG_STYLE=always

# Listen addresses
LISTEN_ADDRESS=0.0.0.0:7000
LISTEN_ADDRESS_TLS=0.0.0.0:7443

# Set to true when running inside Docker (adjusts migration path).
RUNNING_IN_DOCKER=false