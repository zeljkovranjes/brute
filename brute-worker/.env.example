#################
# brute-worker  #  (Cloudflare Workers — set via wrangler secret / [vars])
#################
# These are configured in brute-worker/wrangler.toml or via:
#   wrangler secret put BEARER_TOKEN
#   wrangler secret put ABUSEIPDB_KEY
#
# BEARER_TOKEN   — required, same purpose as brute-http
# ABUSEIPDB_KEY  — optional, same purpose as brute-http
#
# No IPINFO_TOKEN needed — geo data comes from the Cloudflare cf
# request object at no cost.

# Optional — enriches attack records with full IPinfo.io geo data.
# Two ways to enable (set one or both):
#   IPINFO_BASE_URL — set to your round-robin proxy URL; no token required,
#                     the proxy handles auth internally.
#   IPINFO_TOKEN    — set to your IPinfo API token to use https://ipinfo.io
#                     directly without a proxy.
# Leave both empty to fall back to Cloudflare's built-in cf geo data.
# IPINFO_TOKEN = ""
# IPINFO_BASE_URL = ""